---
import Layout from '../layouts/Layout.astro';
import {
  HOUSES,
  levelFromXp,
  requiredXpForLevel,
  HOUSE_LEVEL_COEF,
  HOUSE_LEVEL_EXP,
  USER_LEVEL_COEF,
  USER_LEVEL_EXP,
} from '../lib/houses.ts';

export const prerender = false;

const env = (Astro.locals as { runtime?: { env?: { DB?: D1Database } } }).runtime?.env;

interface HouseTotal {
  house_id: string;
  total_xp: number;
}

let houseTotals: Record<string, number> = {};

if (env?.DB) {
  const r = await env.DB.prepare(
    `SELECT sh.house_id, COALESCE(SUM(ct.total_xp), 0) AS total_xp
     FROM sorting_hat sh
     LEFT JOIN contribution_totals ct ON sh.discord_id = ct.discord_id
     GROUP BY sh.house_id`,
  ).all<HouseTotal>();
  for (const row of r.results ?? []) houseTotals[row.house_id] = row.total_xp;
}

// 個人レベル表（Lv1〜30）
const USER_MAX_LEVEL = 30;
const userRows = Array.from({ length: USER_MAX_LEVEL }, (_, i) => {
  const level = i + 1;
  const cumulative = requiredXpForLevel(level, USER_LEVEL_COEF, USER_LEVEL_EXP);
  const next = requiredXpForLevel(level + 1, USER_LEVEL_COEF, USER_LEVEL_EXP);
  return { level, cumulative, toNext: next - cumulative };
});

// 寮レベル表（Lv1〜15）
const HOUSE_MAX_LEVEL = 15;
const houseRows = Array.from({ length: HOUSE_MAX_LEVEL }, (_, i) => {
  const level = i + 1;
  const cumulative = requiredXpForLevel(level, HOUSE_LEVEL_COEF, HOUSE_LEVEL_EXP);
  const next = requiredXpForLevel(level + 1, HOUSE_LEVEL_COEF, HOUSE_LEVEL_EXP);
  return { level, cumulative, toNext: next - cumulative };
});

function fmt(n: number): string {
  return n.toLocaleString('en-US');
}
---
<Layout title="経験値テーブル｜ぱぶびゅ！">
  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6 sm:py-16">
    <header class="flex flex-col gap-1">
      <p class="text-xs uppercase tracking-[0.3em] text-slate-500">pubview / level table</p>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">📈 経験値テーブル</h1>
      <p class="mt-1 text-sm text-slate-400">
        個人 / 寮それぞれのレベル到達に必要な累積XPと、次レベルまでに必要なXP増分。
      </p>
    </header>

    <!-- 計算式 -->
    <section class="mt-8 rounded-2xl bg-slate-900/60 p-5 ring-1 ring-slate-800 sm:p-6">
      <h2 class="text-lg font-bold">計算式</h2>
      <div class="mt-3 grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl bg-slate-950/60 p-4 ring-1 ring-slate-800">
          <div class="text-xs uppercase tracking-wider text-slate-400">個人</div>
          <div class="mt-1 font-mono text-base text-slate-100">
            Lv<sub>N</sub> 必要累積XP = <span class="text-emerald-300">{USER_LEVEL_COEF}</span> × N<sup>{USER_LEVEL_EXP}</sup>
          </div>
          <p class="mt-2 text-xs text-slate-500">テキスト1通 / VC在室 / SoloQ などで XP を獲得。</p>
        </div>
        <div class="rounded-xl bg-slate-950/60 p-4 ring-1 ring-slate-800">
          <div class="text-xs uppercase tracking-wider text-slate-400">寮</div>
          <div class="mt-1 font-mono text-base text-slate-100">
            Lv<sub>N</sub> 必要累積XP = <span class="text-emerald-300">{HOUSE_LEVEL_COEF}</span> × N<sup>{HOUSE_LEVEL_EXP}</sup>
          </div>
          <p class="mt-2 text-xs text-slate-500">寮の累積XPは所属メンバー全員の <code>total_xp</code> の合計。</p>
        </div>
      </div>
    </section>

    <!-- 現在の寮進捗 -->
    <section class="mt-8">
      <h2 class="text-lg font-bold">現在の寮レベル</h2>
      <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {HOUSES.map((h) => {
          const total = houseTotals[h.id] ?? 0;
          const level = levelFromXp(total, HOUSE_LEVEL_COEF, HOUSE_LEVEL_EXP);
          const curXp = requiredXpForLevel(level, HOUSE_LEVEL_COEF, HOUSE_LEVEL_EXP);
          const nextXp = requiredXpForLevel(level + 1, HOUSE_LEVEL_COEF, HOUSE_LEVEL_EXP);
          const inLv = total - curXp;
          const span = Math.max(1, nextXp - curXp);
          const progress = Math.min(100, Math.max(0, (inLv / span) * 100));
          return (
            <article class={`rounded-2xl ${h.themeBg} p-4 ring-1 ${h.themeRing}`}>
              <div class="flex items-start justify-between">
                <div>
                  <div class="text-3xl leading-none">{h.emoji}</div>
                  <h3 class={`mt-1 text-sm font-bold ${h.themeAccent}`}>{h.name}</h3>
                </div>
                <div class="text-right">
                  <div class="text-xs text-slate-400">寮Lv</div>
                  <div class="text-2xl font-black tabular-nums">{level}</div>
                </div>
              </div>
              <div class="mt-3 text-xs text-slate-400">累積 <span class="font-mono text-slate-200">{fmt(total)}</span> XP</div>
              <div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-900/70">
                <div class={`h-full ${h.themeBar}`} style={`width: ${progress}%`}></div>
              </div>
              <div class="mt-1 flex items-baseline justify-between text-[10px] text-slate-500">
                <span>次Lv {level + 1} まで</span>
                <span class="font-mono tabular-nums">{fmt(inLv)} / {fmt(nextXp - curXp)} XP</span>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <!-- 個人レベル表 -->
    <section class="mt-10">
      <div class="flex items-baseline justify-between">
        <h2 class="text-lg font-bold">個人レベル表（Lv 1〜{USER_MAX_LEVEL}）</h2>
        <p class="text-xs text-slate-500">{USER_LEVEL_COEF} × N<sup>{USER_LEVEL_EXP}</sup></p>
      </div>
      <div class="mt-3 overflow-x-auto rounded-2xl bg-slate-900/60 ring-1 ring-slate-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-800 text-slate-400">
              <th class="px-4 py-3 text-left font-medium">Lv</th>
              <th class="px-4 py-3 text-right font-medium">必要累積XP</th>
              <th class="px-4 py-3 text-right font-medium">このレベルから次まで</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            {userRows.map((r) => (
              <tr class="hover:bg-slate-900/40">
                <td class="px-4 py-2 font-bold tabular-nums">Lv {r.level}</td>
                <td class="px-4 py-2 text-right font-mono tabular-nums">{fmt(r.cumulative)}</td>
                <td class="px-4 py-2 text-right font-mono text-slate-300 tabular-nums">+{fmt(r.toNext)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- 寮レベル表 -->
    <section class="mt-10">
      <div class="flex items-baseline justify-between">
        <h2 class="text-lg font-bold">寮レベル表（Lv 1〜{HOUSE_MAX_LEVEL}）</h2>
        <p class="text-xs text-slate-500">{HOUSE_LEVEL_COEF} × N<sup>{HOUSE_LEVEL_EXP}</sup></p>
      </div>
      <div class="mt-3 overflow-x-auto rounded-2xl bg-slate-900/60 ring-1 ring-slate-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-800 text-slate-400">
              <th class="px-4 py-3 text-left font-medium">Lv</th>
              <th class="px-4 py-3 text-right font-medium">必要累積XP</th>
              <th class="px-4 py-3 text-right font-medium">このレベルから次まで</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800">
            {houseRows.map((r) => (
              <tr class="hover:bg-slate-900/40">
                <td class="px-4 py-2 font-bold tabular-nums">Lv {r.level}</td>
                <td class="px-4 py-2 text-right font-mono tabular-nums">{fmt(r.cumulative)}</td>
                <td class="px-4 py-2 text-right font-mono text-slate-300 tabular-nums">+{fmt(r.toNext)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <footer class="mt-12 flex flex-wrap items-center justify-between gap-3 border-t border-slate-800 pt-6 text-xs text-slate-500">
      <div class="flex flex-wrap gap-3">
        <a href="/" class="hover:text-slate-200">🏠 ダッシュボードへ戻る</a>
        <a href="/leaderboard" class="hover:text-slate-200">🏆 全体ランキング</a>
      </div>
    </footer>
  </main>
</Layout>
